# Required for the AI-personalized rollout plan on the results page.
# Without this key, the app falls back to a templated narrative.
ANTHROPIC_API_KEY=

# Optional: send captured emails through Resend.
# Without this key, leads are logged to the server console only.
RESEND_API_KEY=
LEAD_TO_EMAIL=
LEAD_FROM_EMAIL=

# Optional: client-side analytics. Pick ONE provider — or none for console-only.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
